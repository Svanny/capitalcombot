{
  "name": "capitalcombot",
  "version": "0.1.0",
  "description": "Electron desktop app for Capital.com instrument trading, primarily optimized for Gold workflows, with scheduled orders and protection strategies.",
  "author": {
    "name": "Svanny",
    "email": "svanny@users.noreply.github.com"
  },
  "homepage": "https://github.com/Svanny/capitalcombot",
  "repository": {
    "type": "git",
    "url": "https://github.com/Svanny/capitalcombot.git"
  },
  "bugs": {
    "url": "https://github.com/Svanny/capitalcombot/issues"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "dev:plain": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "package:mac": "bash scripts/package-mac.sh",
    "package:linux": "bash scripts/package-linux.sh",
    "package:win:native": "node scripts/package-win-native.mjs",
    "package:win": "bash scripts/package-win-docker.sh",
    "package:all": "pnpm package:mac && pnpm package:win",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "latest",
    "@fontsource/space-grotesk": "latest",
    "electron-store": "latest",
    "keytar": "latest",
    "98.css": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "jsdom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "keytar"
    ]
  }
}
